# Optional runtime configuration

# Retrieval / KB
# KNOWLEDGE_BASE_PATH=integrated_system/app/knowledge_base.json
# TOP_K_RETRIEVAL=3

# Model
# DEFAULT_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
# LOCAL_BASE_MODEL_PATH=/absolute/path/to/downloaded/base/model

# Snowflake (only needed if you want live queries)
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=
# SNOWFLAKE_ROLE=

# App
# LOG_LEVEL=INFO
# API_URL=http://localhost:8000
